# Procurement Intelligence Platform - Environment Variables

# Security
# Generate a new one with: openssl rand -hex 32
SECRET_KEY=development-secret-key-change-me-in-production

# Database
# Example: postgresql://user:password@localhost/procurement_db
DATABASE_URL=postgresql://user:password@localhost/procurement_db

# CORS Config (Comma separated list)
# BACKEND_CORS_ORIGINS=["http://localhost:3000"]
